{
    "name": "frankenpress/mu-plugin",
    "description": "FrankenPress must-use plugin — platform-essential WordPress glue: humanmade/s3-uploads bootstrap (with safety guards), Souin cache invalidator, Site Health adjustments for the immutable-image lockdown, and SMTP mailer for wp_mail. Four components, all platform-housekeeping.",
    "license": "Apache-2.0",
    "type": "wordpress-muplugin",
    "authors": [
        {
            "name": "FrankenPress",
            "email": "hello@eightoeight.io",
            "homepage": "https://eightoeight.io"
        }
    ],
    "support": {
        "issues": "https://github.com/frankenpress/mu-plugin/issues",
        "source": "https://github.com/frankenpress/mu-plugin"
    },
    "require": {
        "php": ">=8.2",
        "composer/installers": "^2.0",
        "humanmade/s3-uploads": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "mockery/mockery": "^1.6",
        "brain/monkey": "^2.6",
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpstan/phpstan": "^1.11"
    },
    "autoload": {
        "psr-4": {
            "FrankenPress\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FrankenPress\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.3"
        },
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "lint": "phpcs",
        "lint:fix": "phpcbf",
        "stan": "phpstan analyse",
        "test": "phpunit",
        "ci": [
            "@lint",
            "@stan",
            "@test"
        ]
    },
    "extra": {
        "installer-paths": {
            "web/app/mu-plugins/{$name}/": [
                "type:wordpress-muplugin"
            ]
        }
    }
}
